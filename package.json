{
  "name": "spark-desktop",
  "version": "0.1.0",
  "description": "Electron desktop client for the Spark project",
  "main": "src/main/index.cjs",
  "scripts": {
    "start": "electron-forge start",
    "dev": "sh -c 'vite --config vite.config.js --host 127.0.0.1 --port 5199 --strictPort & electron-forge start'",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "electron-forge make",
    "test": "vitest",
    "test:unit": "vitest run"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bip39": "^3.1.0",
    "libp2p": "^3.3.4",
    "libp2p-gossipsub": "^0.14.1",
    "libp2p-mdns": "^0.18.0",
    "libp2p-mplex": "^1.0.0",
    "libp2p-noise": "^4.0.0",
    "libp2p-websockets": "^0.16.2",
    "tweetnacl": "^1.0.3",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.3.0",
    "@electron-forge/plugin-vite": "latest",
    "@testing-library/vue": "^8.1.0",
    "@types/electron": "^1.6.10",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.4.2",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/test-utils": "^2.4.11",
    "electron": "^26.0.0",
    "jsdom": "^19.0.0",
    "level": "^8.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^5.0.0",
    "vitest": "^0.34.0",
    "vue-tsc": "^1.5.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "linux",
            "win32"
          ]
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-vite",
          "config": {
            "main": {
              "entry": "src/main/index.ts"
            },
            "renderer": {
              "entry": "src/renderer/index.html",
              "devContentSecurityPolicy": "default-src 'self' 'unsafe-inline' data:; img-src 'self' data:;"
            }
          }
        }
      ]
    }
  }
}
